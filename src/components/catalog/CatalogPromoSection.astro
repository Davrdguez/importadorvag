---
interface Props {
  title: string;
  buttonLabel: string;
  image: string;
  backgroundImage: string;
}

const { title, buttonLabel, image, backgroundImage } = Astro.props;
---

<section class="bg-[#f7f7f7] px-5 py-12 sm:px-8 lg:px-10">
  <div
    class="mx-auto grid max-w-[1280px] items-center gap-8 overflow-hidden rounded-[10px] bg-cover bg-center bg-no-repeat px-8 py-10 text-white lg:grid-cols-[0.8fr_1.2fr]"
    style={`background-image: linear-gradient(90deg, rgba(14,14,14,0.88), rgba(30,30,30,0.48)), url('${backgroundImage}');`}
  >
    <div class="max-w-[340px]">
      <h2 class="font-['Montserrat'] text-[34px] font-semibold leading-[1.08] sm:text-[40px]">
        {title}
      </h2>
      <a
        href="/sobre-nosotros"
        class="mt-6 inline-flex bg-[#d10000] px-6 py-3 font-['Montserrat'] text-[15px] font-bold uppercase tracking-[0.18em] text-white transition hover:bg-[#b70000]"
      >
        {buttonLabel}
      </a>
    </div>

    <div class="flex justify-center lg:justify-end">
      <img src={image} alt="Audi azul en el banner promocional del catalogo" loading="lazy" class="w-full max-w-[520px] object-contain" />
    </div>
  </div>
</section>
