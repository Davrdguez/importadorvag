---
interface BrandCard {
  slug: string;
  name: string;
  badge: string;
  country: string;
  headline: string;
  description: string;
  modelCount: number;
  vehicleCount: number;
}

interface Props {
  brands: readonly BrandCard[];
}

const { brands } = Astro.props;
---

<section class="bg-[#f7f7f7] px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
  <div class="mx-auto max-w-[1280px]">
    <div class="max-w-[760px]">
      <p class="font-['Montserrat'] text-[13px] font-bold uppercase tracking-[0.28em] text-[#d10000]">
        Marcas del grupo VAG
      </p>
      <h2 class="mt-3 font-['Montserrat'] text-[38px] font-semibold text-[#141414] sm:text-[48px]">
        Elige fabricante y entra despues a cada familia de modelos
      </h2>
      <p class="mt-4 text-[16px] leading-8 text-[#747474]">
        La estructura ya queda preparada como haria un importador: primero marca, despues modelo, y por ultimo cada unidad concreta con contacto.
      </p>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
      {brands.map((brand) => (
        <a
          href={`/catalogo/${brand.slug}`}
          class="group rounded-[14px] border border-[#ececec] bg-white p-6 shadow-[0_10px_26px_rgba(0,0,0,0.04)] transition-all duration-300 hover:-translate-y-1 hover:border-[#d10000]/20 hover:shadow-[0_18px_40px_rgba(0,0,0,0.08)]"
        >
          <div class="flex items-center justify-between">
            <span class="inline-flex h-14 w-14 items-center justify-center rounded-full bg-[#111111] font-['Montserrat'] text-[18px] font-bold uppercase text-white">
              {brand.badge}
            </span>
            <span class="font-['Montserrat'] text-[12px] font-bold uppercase tracking-[0.24em] text-[#9b9b9b]">
              {brand.country}
            </span>
          </div>

          <h3 class="mt-6 font-['Montserrat'] text-[28px] font-semibold text-[#141414] transition-colors group-hover:text-[#d10000]">
            {brand.name}
          </h3>
          <p class="mt-3 text-[15px] leading-8 text-[#5d5d5d]">
            {brand.headline}
          </p>
          <p class="mt-4 text-[14px] leading-7 text-[#838383]">
            {brand.description}
          </p>

          <div class="mt-6 flex flex-wrap gap-3">
            <span class="rounded-full bg-[#f3f3f3] px-4 py-2 font-['Montserrat'] text-[12px] font-bold uppercase tracking-[0.18em] text-[#4d4d4d]">
              {brand.modelCount} modelos
            </span>
            <span class="rounded-full bg-[#f3f3f3] px-4 py-2 font-['Montserrat'] text-[12px] font-bold uppercase tracking-[0.18em] text-[#4d4d4d]">
              {brand.vehicleCount} variantes
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
