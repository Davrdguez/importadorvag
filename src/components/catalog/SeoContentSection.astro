---
interface Props {
  eyebrow: string;
  title: string;
  introduction: string;
  paragraphs: readonly string[];
  highlights: readonly string[];
}

const { eyebrow, title, introduction, paragraphs, highlights } = Astro.props;
---

<section class="bg-[#f7f7f7] px-5 py-14 sm:px-8 sm:py-18 lg:px-10">
  <div class="mx-auto grid max-w-[1280px] gap-8 rounded-[18px] border border-[#ececec] bg-white p-6 shadow-[0_16px_36px_rgba(0,0,0,0.05)] lg:grid-cols-[0.62fr_0.38fr] lg:p-10">
    <div>
      <p class="font-['Montserrat'] text-[13px] font-bold uppercase tracking-[0.26em] text-[#d10000]">
        {eyebrow}
      </p>
      <h2 class="mt-3 font-['Montserrat'] text-[32px] font-semibold leading-none text-[#141414] sm:text-[42px]">
        {title}
      </h2>
      <p class="mt-5 text-[16px] leading-8 text-[#5f5f5f]">
        {introduction}
      </p>
      <div class="mt-6 space-y-4">
        {paragraphs.map((paragraph) => (
          <p class="text-[15px] leading-8 text-[#707070]">
            {paragraph}
          </p>
        ))}
      </div>
    </div>

    <div class="grid gap-4 self-start">
      {highlights.map((highlight) => (
        <div class="rounded-[14px] border border-[#ececec] bg-[#fbfbfb] px-5 py-4 shadow-[0_8px_18px_rgba(0,0,0,0.03)]">
          <p class="font-['Montserrat'] text-[13px] font-bold uppercase tracking-[0.2em] text-[#202020]">
            {highlight}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
