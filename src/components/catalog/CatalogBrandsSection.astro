---
interface Props {
  title: string;
  subtitle: string;
  logos: readonly string[];
}

const { title, subtitle, logos } = Astro.props;
---

<section class="bg-[#f7f7f7] px-5 py-16 text-center sm:px-8 sm:py-20 lg:px-10">
  <div class="mx-auto max-w-[1280px]">
    <h2 class="font-['Montserrat'] text-[34px] font-semibold text-[#141414] sm:text-[42px]">
      {title}
    </h2>
    <p class="mt-2 font-['Montserrat'] text-[13px] uppercase tracking-[0.26em] text-[#9a9a9a]">
      {subtitle}
    </p>

    <div class="mx-auto mt-10 grid max-w-[960px] grid-cols-2 gap-4 sm:grid-cols-4 lg:grid-cols-8">
      {logos.map((logo, index) => (
        <div class="flex h-[82px] items-center justify-center rounded-[6px] border border-[#efefef] bg-white p-4">
          <img
            src={logo}
            alt={`Logo de fabricante ${index + 1} en la parrilla del catalogo`}
            loading="lazy"
            class="max-h-10 w-auto object-contain"
          />
        </div>
      ))}
    </div>
  </div>
</section>
