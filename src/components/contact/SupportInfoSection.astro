---
interface SupportCard {
  title: string;
  description: string;
  image: string;
  alt: string;
}

interface Props {
  support: {
    title: string;
    description: string;
    buttonLabel: string;
    backgroundImage: string;
    personImage: string;
    personAlt: string;
  };
  info: {
    heading: string;
    cards: readonly SupportCard[];
  };
}

const { support, info } = Astro.props;
---

<section class="bg-[#f6f6f6] px-5 py-14 text-[#141414] sm:px-8 sm:py-20 lg:px-10">
  <div class="mx-auto grid max-w-[1280px] gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
    <article
      class="relative min-h-[360px] overflow-hidden rounded-[10px] bg-cover bg-center"
      style={`background-image: linear-gradient(90deg, rgba(14,14,14,0.88), rgba(14,14,14,0.54)), url('${support.backgroundImage}');`}
    >
      <img
        src={support.personImage}
        alt={support.personAlt}
        loading="lazy"
        class="absolute bottom-0 left-0 w-[45%] max-w-[250px] object-contain"
      />
      <div class="relative ml-auto flex min-h-[360px] w-full max-w-[56%] flex-col justify-center px-6 py-8 text-left sm:px-10">
        <h2 class="font-['Montserrat'] text-[30px] font-semibold uppercase leading-none text-white sm:text-[34px]">
          {support.title}
        </h2>
        <p class="mt-4 text-[15px] leading-7 text-white/75">
          {support.description}
        </p>
        <a
          href="/contacto"
          class="mt-6 inline-flex w-max bg-[#d10000] px-6 py-3 font-['Montserrat'] text-[15px] font-bold uppercase tracking-[0.18em] text-white transition hover:bg-[#b70000]"
        >
          {support.buttonLabel}
        </a>
      </div>
    </article>

    <div>
      <h2 class="font-['Montserrat'] text-[34px] font-semibold leading-none text-[#141414] sm:text-[42px]">
        {info.heading}
      </h2>

      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        {info.cards.map((card) => (
          <article class="rounded-[10px] border border-[#ebebeb] bg-[linear-gradient(180deg,_#ffffff,_#f6f6f6)] px-6 py-7 shadow-[0_8px_24px_rgba(0,0,0,0.04)]">
            <img src={card.image} alt={card.alt} loading="lazy" class="h-10 w-10 object-contain" />
            <h3 class="mt-5 font-['Montserrat'] text-[20px] font-semibold text-[#d10000]">
              {card.title}
            </h3>
            <p class="mt-2 text-[14px] leading-7 text-[#7d7d7d]">
              {card.description}
            </p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
