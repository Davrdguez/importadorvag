---
interface Props {
  testimonial: {
    quote: string;
    name: string;
    role: string;
    personImage: string;
    personAlt: string;
    backgroundImage: string;
  };
  joinTeam: {
    title: string;
    body: string;
    buttonLabel: string;
    backgroundImage: string;
  };
}

const { testimonial, joinTeam } = Astro.props;
---

<section class="bg-[#f6f6f6] px-5 pb-12 text-white sm:px-8 sm:pb-16 lg:px-10 lg:pb-20">
  <div class="mx-auto grid max-w-[1280px] gap-6 lg:grid-cols-2">
    <article
      class="relative min-h-[320px] overflow-hidden rounded-[8px] bg-cover bg-center"
      style={`background-image: linear-gradient(90deg, rgba(16,16,16,0.88), rgba(42,42,42,0.55)), url('${testimonial.backgroundImage}');`}
    >
      <img
        src={testimonial.personImage}
        alt={testimonial.personAlt}
        loading="lazy"
        class="absolute bottom-0 left-0 w-[46%] max-w-[240px] object-contain sm:w-[40%]"
      />
      <div class="relative ml-auto flex min-h-[320px] w-full max-w-[58%] flex-col justify-center px-6 py-10 text-right sm:px-10">
        <p class="text-[15px] leading-8 text-white/75 sm:text-[16px]">
          {testimonial.quote}
        </p>
        <p class="mt-8 font-['Montserrat'] text-[24px] font-semibold text-white">
          {testimonial.name}
        </p>
        <p class="mt-1 text-[13px] uppercase tracking-[0.18em] text-white/60">
          {testimonial.role}
        </p>
      </div>
    </article>

    <article
      class="relative min-h-[320px] overflow-hidden rounded-[8px] bg-cover bg-center"
      style={`background-image: linear-gradient(180deg, rgba(16,16,16,0.52), rgba(16,16,16,0.72)), url('${joinTeam.backgroundImage}');`}
    >
      <div class="flex min-h-[320px] max-w-[340px] flex-col justify-end px-6 py-8 sm:px-10 sm:py-10">
        <h2 class="font-['Montserrat'] text-[30px] font-semibold uppercase leading-none text-white sm:text-[36px]">
          {joinTeam.title}
        </h2>
        <p class="mt-4 text-[15px] leading-8 text-white/75 sm:text-[16px]">
          {joinTeam.body}
        </p>
        <a
          href="#"
          class="mt-6 inline-flex w-max border border-white/70 px-5 py-3 font-['Montserrat'] text-[16px] font-bold uppercase tracking-[0.16em] text-white transition-all hover:border-red-500 hover:bg-red-600"
        >
          {joinTeam.buttonLabel}
        </a>
      </div>
    </article>
  </div>
</section>
