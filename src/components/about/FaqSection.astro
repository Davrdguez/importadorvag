---
interface FaqItem {
  title: string;
  content: string;
}

interface Props {
  title: string;
  items: readonly FaqItem[];
  cta: {
    title: string;
    body: string;
    buttonLabel: string;
    backgroundImage: string;
    overlayImage: string;
    overlayAlt: string;
  };
}

const { title, items, cta } = Astro.props;
---

<section class="bg-[#f6f6f6] px-5 py-12 text-[#141414] sm:px-8 sm:py-16 lg:px-10 lg:py-20">
  <div class="mx-auto max-w-[1280px]">
    <h2 class="font-['Montserrat'] text-[34px] font-bold text-[#d10000] sm:text-[40px]">
      {title}
    </h2>

    <div class="mt-8 grid gap-8 lg:grid-cols-2 lg:items-start">
      <div class="space-y-3">
        {items.map((item, index) => (
          <details class="group overflow-hidden rounded-[6px] border border-white bg-white shadow-[0_10px_24px_rgba(0,0,0,0.04)]" open={index === 0}>
            <summary class="flex cursor-pointer list-none items-center justify-between bg-[#d10000] px-5 py-4 font-['Montserrat'] text-[16px] font-semibold text-white marker:hidden">
              <span>{item.title}</span>
              <span class="text-[24px] leading-none group-open:hidden">+</span>
              <span class="hidden text-[24px] leading-none group-open:inline">-</span>
            </summary>
            <div class="px-5 py-5 text-[15px] leading-8 text-[#767676]">
              {item.content}
            </div>
          </details>
        ))}
      </div>

      <article
        class="relative overflow-hidden rounded-[8px] bg-cover bg-center px-7 py-8 text-white sm:px-10 sm:py-10"
        style={`background-image: linear-gradient(180deg, rgba(12,12,12,0.78), rgba(12,12,12,0.82)), url('${cta.backgroundImage}');`}
      >
        <div class="relative z-10 max-w-[320px]">
          <h3 class="font-['Montserrat'] text-[26px] font-semibold leading-[1.1] sm:text-[32px]" set:html={cta.title}></h3>
          <p class="mt-4 text-[15px] leading-7 text-white/75">
            {cta.body}
          </p>
          <a
            href="/contacto"
            class="mt-6 inline-flex bg-[#c50000] px-6 py-3 font-['Montserrat'] text-[16px] font-bold uppercase tracking-[0.16em] text-white transition-all hover:bg-white hover:text-[#111111]"
          >
            {cta.buttonLabel}
          </a>
        </div>

        <img
          src={cta.overlayImage}
          alt={cta.overlayAlt}
          loading="lazy"
          class="pointer-events-none absolute bottom-0 right-0 w-[46%] min-w-[170px] max-w-[260px] object-contain"
        />
      </article>
    </div>
  </div>
</section>
