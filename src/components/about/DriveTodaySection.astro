---
interface Props {
  title: string;
  body: string;
  buttonLabel: string;
  backgroundImage: string;
  carImage: string;
  carAlt: string;
}

const { title, body, buttonLabel, backgroundImage, carImage, carAlt } = Astro.props;
---

<section class="bg-[#f6f6f6] px-5 py-6 sm:px-8 sm:py-8 lg:px-10">
  <div
    class="mx-auto grid max-w-[1600px] items-center gap-10 overflow-hidden bg-cover bg-center bg-no-repeat px-8 py-10 text-white sm:px-12 sm:py-14 lg:grid-cols-[0.9fr_1.1fr]"
    style={`background-image: linear-gradient(90deg, rgba(212,9,9,0.95), rgba(212,9,9,0.95)), url('${backgroundImage}');`}
  >
    <div class="max-w-[420px]">
      <h2 class="font-['Montserrat'] text-[34px] font-bold leading-tight sm:text-[42px]">
        {title}
      </h2>
      <p class="mt-4 text-[16px] leading-8 text-white/80">
        {body}
      </p>
      <a
        href="/contacto"
        class="mt-7 inline-flex rounded-[10px] bg-[#111111] px-7 py-4 font-['Montserrat'] text-[17px] font-bold uppercase tracking-[0.18em] text-white transition-all hover:bg-white hover:text-[#111111]"
      >
        {buttonLabel}
      </a>
    </div>

    <div class="relative flex justify-center lg:justify-end">
      <img
        src={carImage}
        alt={carAlt}
        loading="lazy"
        class="w-full max-w-[700px] object-contain drop-shadow-[0_28px_30px_rgba(0,0,0,0.45)]"
      />
    </div>
  </div>
</section>
