<section id="about" class="bg-[#f5f5f5] px-5 pb-14 sm:px-8 lg:px-12">
  <div class="mx-auto grid max-w-[1280px] gap-6 md:grid-cols-2">
    <article
      class="relative min-h-[240px] overflow-hidden rounded-[2px] border border-[#e4e4e4] bg-cover bg-center p-8 text-white shadow-[0_14px_32px_rgba(0,0,0,0.06)] lg:min-h-[250px]"
      style={`background-image: linear-gradient(90deg, rgba(11,11,11,0.88), rgba(11,11,11,0.18)), url('http://demo2.strongtheme.com/autocar/wp-content/uploads/sites/3/2021/07/autohomeei01.jpg');`}
    >
      <div class="max-w-[220px]">
        <h2 class="font-['Montserrat'] text-[28px] font-semibold leading-none sm:text-[34px]">Como importamos tu coche?</h2>
        <a href="#proceso" class="mt-8 inline-flex bg-red-600 px-5 py-2.5 font-['Montserrat'] text-[13px] font-bold uppercase tracking-[0.2em] text-white">
          Ver proceso
        </a>
      </div>
      <img
        src="http://demo2.strongtheme.com/autocar/wp-content/uploads/sites/3/2021/07/autohome011.png"
        alt="Jeep rojo usado como decoracion del bloque del proceso"
        loading="lazy"
        class="absolute bottom-0 right-0 w-[46%] object-contain"
      />
    </article>

    <article class="relative min-h-[240px] overflow-hidden rounded-[2px] border border-[#e4e4e4] bg-[linear-gradient(120deg,_#1a1a1a,_#3b3b3b)] p-8 text-white shadow-[0_14px_32px_rgba(0,0,0,0.06)] lg:min-h-[250px]">
      <div class="max-w-[240px]">
        <h2 class="font-['Montserrat'] text-[26px] font-semibold leading-none sm:text-[32px]">Quieres encontrar <br />tu coche ideal?</h2>
        <p class="mt-4 max-w-[23ch] text-[13px] leading-6 text-white/70">Buscamos unidades con historial coherente y revision previa antes de proponertelas.</p>
        <a href="/contacto" class="mt-7 inline-flex bg-red-600 px-5 py-2.5 font-['Montserrat'] text-[13px] font-bold uppercase tracking-[0.2em] text-white">
          Contactar
        </a>
      </div>
      <img
        src="http://demo2.strongtheme.com/autocar/wp-content/uploads/sites/3/2021/07/autohome028.png"
        alt="Figura decorativa para el banner de busqueda de coche"
        loading="lazy"
        class="absolute bottom-0 right-0 h-full max-w-[42%] object-contain"
      />
    </article>
  </div>
</section>
