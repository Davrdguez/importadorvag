---
import VehicleCard from "../shared/VehicleCard.astro";
import { featuredVehicles } from "../../data/catalog";

---

<section id="catalogo" class="bg-[#fcfcfc] px-5 py-20 sm:px-8 lg:px-12">
  <div class="mx-auto max-w-[1280px]">
    <div class="mb-12 flex flex-col items-start justify-between gap-6 border-b border-neutral-200 pb-8 md:flex-row md:items-end">
      <div>
        <p class="font-['Montserrat'] text-[12px] font-bold uppercase tracking-[0.4em] text-red-600">Premium Selection</p>
        <h2 class="mt-2 font-['Montserrat'] text-4xl font-extrabold uppercase tracking-tighter text-[#151515] sm:text-5xl">
          Featured <span class="text-neutral-400">Inventory</span>
        </h2>
      </div>
      <a href="/catalogo" class="font-['Montserrat'] text-[13px] font-bold uppercase tracking-[0.2em] text-neutral-900 transition-colors hover:text-red-600">
        View All Models //
      </a>
    </div>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {featuredVehicles.map((vehicle) => (
        <VehicleCard vehicle={vehicle} ctaLabel="Ver ficha y contactar" />
      ))}
    </div>
  </div>
</section>
