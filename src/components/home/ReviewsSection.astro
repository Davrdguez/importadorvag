---
import { reviews } from "../../data/home";
---

<section class="bg-[#f5f5f5] px-5 pt-14 sm:px-8 lg:px-12">
  <div class="text-center">
    <div class="inline-flex bg-red-600 px-8 py-3 font-['Montserrat'] text-[24px] font-semibold text-white">
      Opiniones recientes
    </div>
  </div>
</section>

<section class="bg-[#f5f5f5] px-5 pb-16 pt-8 sm:px-8 lg:px-12">
  <div class="mx-auto grid max-w-[1280px] gap-6 lg:grid-cols-[0.82fr_1fr_1fr]">
    <img
      src="http://demo2.strongtheme.com/autocar/wp-content/uploads/sites/3/2021/07/autohomeei040.jpg"
      alt="Clientes revisando un coche en la seccion de testimonios"
      loading="lazy"
      width="320"
      height="220"
      class="h-full min-h-[220px] w-full self-start object-cover"
    />
    {reviews.map((review) => (
      <article
        class="border border-red-300 bg-white px-8 py-8 shadow-[0_12px_26px_rgba(0,0,0,0.04)]"
        style={`background-image: url('http://demo2.strongtheme.com/autocar/wp-content/uploads/sites/3/2021/07/autolisting032.png'); background-repeat: no-repeat; background-position: top right; background-size: 92% auto;`}
      >
        <p class="font-['Montserrat'] text-6xl leading-none text-red-200">"</p>
        <p class="mt-5 text-sm leading-7 text-neutral-500">{review.body}</p>
        <div class="mt-6 flex items-center gap-4">
          <img src={review.avatar} alt={review.alt} loading="lazy" class="h-10 w-10 rounded-full object-cover" />
          <div>
            <p class="font-['Montserrat'] text-lg font-semibold text-red-500">{review.name}</p>
            <p class="font-['Montserrat'] text-[11px] uppercase tracking-[0.2em] text-neutral-400">{review.role}</p>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
