---
---

<section
  id="contacto"
  class="grid bg-black lg:grid-cols-[1.08fr_0.92fr]"
  style={`background-image: linear-gradient(180deg, rgba(0,0,0,0.12), rgba(0,0,0,0.12)), url('http://demo2.strongtheme.com/autocar/wp-content/uploads/sites/3/2021/07/autohomeei018.jpg'); background-repeat: no-repeat; background-size: 62% auto; background-position: left 91%;`}
>
  <div class="min-h-[360px]"></div>
  <div class="px-5 py-12 sm:px-8 lg:px-10">
    <div class="mx-auto max-w-[420px]">
      <div class="inline-flex bg-red-600 px-6 py-3 font-['Montserrat'] text-[20px] font-semibold text-white">
        Solicita tu busqueda
      </div>
      <form class="mt-8 grid gap-3">
        <div class="grid gap-3 sm:grid-cols-2">
          <input type="text" placeholder="NOMBRE" class="border border-red-950/80 bg-black/10 px-4 py-3 font-['Montserrat'] text-[13px] uppercase tracking-[0.18em] text-white outline-none placeholder:text-white/55 focus:border-red-700" />
          <input type="text" placeholder="APELLIDOS" class="border border-red-950/80 bg-black/10 px-4 py-3 font-['Montserrat'] text-[13px] uppercase tracking-[0.18em] text-white outline-none placeholder:text-white/55 focus:border-red-700" />
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          <input type="text" placeholder="TELEFONO" class="border border-red-950/80 bg-black/10 px-4 py-3 font-['Montserrat'] text-[13px] uppercase tracking-[0.18em] text-white outline-none placeholder:text-white/55 focus:border-red-700" />
          <input type="email" placeholder="CORREO ELECTRONICO" class="border border-red-950/80 bg-black/10 px-4 py-3 font-['Montserrat'] text-[13px] uppercase tracking-[0.18em] text-white outline-none placeholder:text-white/55 focus:border-red-700" />
        </div>
        <input type="text" placeholder="MODELO DE INTERES" class="border border-red-950/80 bg-black/10 px-4 py-3 font-['Montserrat'] text-[13px] uppercase tracking-[0.18em] text-white outline-none placeholder:text-white/55 focus:border-red-700" />
        <input type="text" placeholder="TU UBICACION" class="border border-red-950/80 bg-black/10 px-4 py-3 font-['Montserrat'] text-[13px] uppercase tracking-[0.18em] text-white outline-none placeholder:text-white/55 focus:border-red-700" />
        <button id="cta-importacion" type="submit" class="mt-2 bg-red-600 px-6 py-3 font-['Montserrat'] text-[14px] font-bold uppercase tracking-[0.22em] text-white transition hover:bg-red-500">
          Enviar
        </button>
      </form>
    </div>
  </div>
</section>
