---
import type { BlogPostPreview } from "../../data/blog";
import BlogPostCard from "../blog/BlogPostCard.astro";

interface Props {
  posts: readonly BlogPostPreview[];
}

const { posts } = Astro.props;
---

<section id="proceso" class="bg-[#f5f5f5] px-5 pb-6 text-center sm:px-8 lg:px-12">
  <p class="font-['Montserrat'] text-[11px] uppercase tracking-[0.34em] text-neutral-500">Desde nuestro blog</p>
  <div class="mt-4 inline-flex bg-red-600 px-9 py-3 font-['Montserrat'] text-[24px] font-semibold text-white">
    Guias de compra utiles
  </div>
</section>

<section id="blog" class="bg-[#f5f5f5] px-5 pb-16 pt-6 sm:px-8 lg:px-12">
  <div class="mx-auto grid max-w-[1280px] gap-x-6 gap-y-8 sm:grid-cols-2 lg:grid-cols-3">
    {posts.map((post) => (
      <BlogPostCard post={post} compact />
    ))}
  </div>
  <div class="mx-auto mt-10 max-w-[1280px] text-center">
    <a
      href="/blog"
      class="inline-flex bg-[#d10000] px-6 py-3 font-['Montserrat'] text-[14px] font-bold uppercase tracking-[0.2em] text-white transition hover:bg-[#b30000]"
    >
      Ver todos los articulos
    </a>
  </div>
</section>
