<section
  class="relative overflow-hidden bg-cover bg-center px-5 py-16 sm:px-8 lg:px-12 lg:py-20"
  style={`background-image: linear-gradient(180deg, rgba(4,4,4,0.82), rgba(4,4,4,0.96)), url('http://demo2.strongtheme.com/autocar/wp-content/uploads/sites/3/2021/07/autohome022.png');`}
>
  <div class="mx-auto grid max-w-[1280px] gap-5 md:grid-cols-2 lg:max-w-[760px]">
    <article
      class="border border-white/25 px-7 py-8 text-center text-white shadow-[0_20px_40px_rgba(0,0,0,0.2)]"
      style={`background-image: linear-gradient(180deg, rgba(18,1,1,0.8), rgba(18,1,1,0.88)), url('http://demo2.strongtheme.com/autocar/wp-content/uploads/sites/3/2021/07/autohome013.png'); background-size: cover; background-position: center;`}
    >
      <h2 class="font-['Montserrat'] text-[26px] font-semibold uppercase sm:text-[30px]">Importar coche</h2>
      <p class="mx-auto mt-4 max-w-[240px] text-[13px] leading-6 text-white/68">
        Seleccionamos unidades de Alemania con mas criterio, mas filtro previo y mejor base mecanica.
      </p>
      <a href="/contacto" class="mt-6 inline-flex bg-red-600 px-5 py-2.5 font-['Montserrat'] text-[13px] font-bold uppercase tracking-[0.22em] text-white">
        Mas informacion
      </a>
    </article>
    <article
      class="border border-white/25 px-7 py-8 text-center text-white shadow-[0_20px_40px_rgba(0,0,0,0.2)]"
      style={`background-image: linear-gradient(180deg, rgba(18,1,1,0.8), rgba(18,1,1,0.88)), url('http://demo2.strongtheme.com/autocar/wp-content/uploads/sites/3/2021/07/autohome013.png'); background-size: cover; background-position: center;`}
    >
      <h2 class="font-['Montserrat'] text-[26px] font-semibold uppercase sm:text-[30px]">Asesoria personalizada</h2>
      <p class="mx-auto mt-4 max-w-[240px] text-[13px] leading-6 text-white/68">
        Resolvemos dudas de modelos, motores, documentacion, revision tecnica y matriculacion.
      </p>
      <a href="/contacto" class="mt-6 inline-flex bg-red-600 px-5 py-2.5 font-['Montserrat'] text-[13px] font-bold uppercase tracking-[0.22em] text-white">
        Mas informacion
      </a>
    </article>
  </div>

  <div class="pointer-events-none absolute inset-x-0 bottom-10 h-20 bg-[radial-gradient(circle_at_10%_100%,_rgba(255,255,255,0.85),_transparent_18%),radial-gradient(circle_at_25%_100%,_rgba(255,255,255,0.65),_transparent_16%),radial-gradient(circle_at_50%_100%,_rgba(255,255,255,0.75),_transparent_14%),radial-gradient(circle_at_75%_100%,_rgba(255,255,255,0.65),_transparent_16%),radial-gradient(circle_at_90%_100%,_rgba(255,255,255,0.8),_transparent_18%)] opacity-40 blur-md"></div>
  <img
    src="http://demo2.strongtheme.com/autocar/wp-content/uploads/sites/3/2021/07/autohome012.png"
    alt="Coche rojo situado sobre una malla blanca en la seccion principal"
    loading="lazy"
    class="relative mx-auto mt-8 h-auto w-full max-w-[360px] object-contain sm:max-w-[420px] lg:max-w-[470px]"
  />
</section>
