---
import type { BlogPostPreview } from "../../data/blog";
import BlogPostCard from "./BlogPostCard.astro";

interface Props {
  posts: readonly BlogPostPreview[];
  title?: string;
  description?: string;
}

const {
  posts,
  title = "Articulos destacados",
  description = "Contenido pensado para atacar busquedas reales sobre importacion de coches diesel desde Alemania."
} = Astro.props;
---

<section class="bg-[#f6f6f6] px-5 py-14 text-[#141414] sm:px-8 sm:py-18 lg:px-10">
  <div class="mx-auto max-w-[1280px]">
    <div class="max-w-[760px]">
      <p class="font-['Montserrat'] text-[12px] font-bold uppercase tracking-[0.26em] text-[#d10000]">
        Contenido SEO
      </p>
      <h2 class="mt-3 font-['Montserrat'] text-[34px] font-semibold text-[#141414] sm:text-[44px]">
        {title}
      </h2>
      <p class="mt-4 text-[16px] leading-8 text-[#6d6d6d]">
        {description}
      </p>
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {posts.map((post) => (
        <BlogPostCard post={post} />
      ))}
    </div>
  </div>
</section>
