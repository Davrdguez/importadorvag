---
interface Props {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  publishDate: Date;
  updatedDate?: Date;
  author: string;
  tags: readonly string[];
}

const { title, description, image, imageAlt, publishDate, updatedDate, author, tags } = Astro.props;

const published = publishDate.toLocaleDateString("es-ES", {
  day: "2-digit",
  month: "long",
  year: "numeric"
});

const updated = updatedDate
  ? updatedDate.toLocaleDateString("es-ES", {
      day: "2-digit",
      month: "long",
      year: "numeric"
    })
  : null;
---

<article class="bg-[#f6f6f6] px-5 py-14 text-[#141414] sm:px-8 sm:py-18 lg:px-10">
  <div class="mx-auto max-w-[980px]">
    <div class="rounded-[18px] border border-[#ececec] bg-white p-6 shadow-[0_16px_36px_rgba(0,0,0,0.05)] sm:p-8">
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="rounded-full bg-[#f3f3f3] px-3 py-1 font-['Montserrat'] text-[11px] font-bold uppercase tracking-[0.18em] text-[#575757]">
            {tag}
          </span>
        ))}
      </div>

      <h1 class="mt-5 font-['Montserrat'] text-[34px] font-semibold leading-[1.02] text-[#141414] sm:text-[48px]">
        {title}
      </h1>

      <p class="mt-5 text-[17px] leading-8 text-[#666666]">
        {description}
      </p>

      <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 font-['Montserrat'] text-[12px] uppercase tracking-[0.18em] text-[#8a8a8a]">
        <span>Publicado: {published}</span>
        {updated && <span>Actualizado: {updated}</span>}
        <span>Autor: {author}</span>
      </div>

      <img
        src={image}
        alt={imageAlt}
        loading="eager"
        class="mt-8 aspect-[1.65/1] w-full rounded-[14px] object-cover shadow-[0_18px_34px_rgba(0,0,0,0.08)]"
      />

      <div class="mt-10 [&_a]:font-semibold [&_a]:text-[#d10000] [&_blockquote]:border-l-4 [&_blockquote]:border-[#d10000] [&_blockquote]:bg-[#faf7f7] [&_blockquote]:px-5 [&_blockquote]:py-4 [&_blockquote]:text-[17px] [&_blockquote]:leading-8 [&_blockquote]:text-[#4a4a4a] [&_h2]:mt-10 [&_h2]:font-['Montserrat'] [&_h2]:text-[30px] [&_h2]:font-semibold [&_h2]:leading-none [&_h2]:text-[#141414] [&_h3]:mt-8 [&_h3]:font-['Montserrat'] [&_h3]:text-[24px] [&_h3]:font-semibold [&_h3]:leading-none [&_h3]:text-[#141414] [&_li]:text-[16px] [&_li]:leading-8 [&_li]:text-[#5f5f5f] [&_ol]:mt-5 [&_ol]:list-decimal [&_ol]:space-y-2 [&_ol]:pl-6 [&_p]:mt-5 [&_p]:text-[16px] [&_p]:leading-8 [&_p]:text-[#5f5f5f] [&_strong]:text-[#141414] [&_ul]:mt-5 [&_ul]:list-disc [&_ul]:space-y-2 [&_ul]:pl-6">
        <slot />
      </div>
    </div>
  </div>
</article>
