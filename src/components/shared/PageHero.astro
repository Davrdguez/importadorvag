---
import HeaderSection from "../home/HeaderSection.astro";

interface Props {
  title: string;
  backgroundImage: string;
  activePath?: string;
}

const { title, backgroundImage, activePath = "/" } = Astro.props;
---

<section
  class="relative overflow-hidden bg-cover bg-center bg-no-repeat"
  style={`background-image: linear-gradient(180deg, rgba(15,15,15,0.82), rgba(15,15,15,0.88)), url('${backgroundImage}');`}
>
  <HeaderSection activePath={activePath} />

  <div class="mx-auto max-w-[1280px] px-5 pb-7 pt-16 sm:px-8 sm:pb-9 sm:pt-20 lg:px-10 lg:pb-12">
    <h1 class="font-['Montserrat'] text-[18px] font-medium tracking-[0.02em] text-white sm:text-[20px]">
      {title}
    </h1>
  </div>
</section>
