---
import { getCatalogVehiclePath, type CatalogVehicle } from "../../data/catalog";

interface Props {
  vehicle: CatalogVehicle;
  variant?: "grid" | "sidebar";
  ctaLabel?: string;
  href?: string;
}

const {
  vehicle,
  variant = "grid",
  ctaLabel = "Consultar vehiculo",
  href = getCatalogVehiclePath(vehicle)
} = Astro.props;
const isSidebar = variant === "sidebar";
const ribbonLabel = vehicle.price || vehicle.engine || vehicle.power || "Consultar";
---

<article class:list={[
  "group rounded-[10px] border border-[#efefef] bg-white shadow-[0_8px_24px_rgba(0,0,0,0.04)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_18px_38px_rgba(0,0,0,0.08)]",
  isSidebar ? "p-4" : "p-5 sm:p-6"
]}>
  <div class="flex items-center justify-between font-['Montserrat'] text-[11px] uppercase tracking-[0.22em] text-[#9d9d9d]">
    <span>{vehicle.meta}</span>
    <span>{vehicle.year}</span>
  </div>

  <div class:list={["mt-4 overflow-hidden bg-[#fafafa]", isSidebar ? "rounded-[8px]" : "rounded-[10px]"]}>
    <img
      src={vehicle.image}
      alt={vehicle.alt}
      loading="lazy"
      class:list={[
        "w-full object-contain transition-transform duration-500 group-hover:scale-[1.04]",
        isSidebar ? "h-[150px] p-2" : "h-[180px] p-3"
      ]}
    />
  </div>

  <div class="mt-5 flex items-start justify-between gap-4">
    <h3 class:list={[
      "font-['Montserrat'] font-semibold uppercase leading-none text-[#131313]",
      isSidebar ? "text-[22px]" : "text-[24px]"
    ]}>
      {vehicle.name}
    </h3>
    <span class="inline-flex bg-[linear-gradient(90deg,_#d10000,_#ff2200)] px-4 py-2 font-['Montserrat'] text-[15px] font-bold text-white [clip-path:polygon(12%_0,100%_0,88%_100%,0_100%)]">
      {ribbonLabel}
    </span>
  </div>

  <div class="mt-4 flex flex-wrap gap-x-4 gap-y-2 font-['Montserrat'] text-[12px] uppercase tracking-[0.16em] text-[#8b8b8b]">
    <span>{vehicle.mileage}</span>
    <span>{vehicle.transmission}</span>
    <span>{vehicle.brand}</span>
  </div>

  <a
    href={href}
    class="mt-5 inline-flex font-['Montserrat'] text-[14px] font-bold uppercase tracking-[0.18em] text-[#d10000] transition-all hover:tracking-[0.22em]"
  >
    {ctaLabel}
  </a>
</article>
