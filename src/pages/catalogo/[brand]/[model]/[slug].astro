---
import VehicleDetailSection from "../../../../components/catalog/VehicleDetailSection.astro";
import FooterSection from "../../../../components/home/FooterSection.astro";
import Breadcrumbs from "../../../../components/shared/Breadcrumbs.astro";
import PageHero from "../../../../components/shared/PageHero.astro";
import {
  catalogVehicles,
  detailHero,
  detailPopularCars,
  detailQuestionCard,
  detailSidebar,
  getBrandBySlug,
  getCatalogVehicleBySlug,
  type CatalogVehicle
} from "../../../../data/catalog";
import Layout from "../../../../layouts/Layout.astro";
import { siteUrl } from "../../../../data/site";

export function getStaticPaths() {
  return catalogVehicles.map((vehicle: CatalogVehicle) => ({
    params: {
      brand: vehicle.brandSlug,
      model: vehicle.modelSlug,
      slug: vehicle.slug
    },
    props: { vehicle }
  }));
}

const { vehicle } = Astro.props as { vehicle: CatalogVehicle };
const brand = getBrandBySlug(vehicle.brandSlug);
const popularVehicles = detailPopularCars
  .flatMap((slug: string) => {
    const item = getCatalogVehicleBySlug(slug);
    return item ? [item] : [];
  })
  .filter((item: CatalogVehicle) => item.slug !== vehicle.slug);

const title = `${vehicle.name} | ${brand?.name ?? vehicle.brand}`;
const description = `Ficha individual de ${vehicle.name} con contacto directo, datos mecanicos y solicitud de disponibilidad.`;
const canonical = `${siteUrl}/catalogo/${vehicle.brandSlug}/${vehicle.modelSlug}/${vehicle.slug}`;

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Catalogo", href: "/catalogo" },
  { label: brand?.name ?? vehicle.brand, href: `/catalogo/${vehicle.brandSlug}` },
  { label: vehicle.model, href: `/catalogo/${vehicle.brandSlug}/${vehicle.modelSlug}` },
  { label: vehicle.trim }
] as const;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Car",
    name: vehicle.name,
    image: vehicle.gallery,
    description,
    brand: brand?.name ?? vehicle.brand,
    model: vehicle.model,
    vehicleModelDate: vehicle.year,
    fuelType: vehicle.fuel,
    vehicleTransmission: vehicle.transmission
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Inicio", item: "https://importarvagalemania.vercel.app/" },
      { "@type": "ListItem", position: 2, name: "Catalogo", item: "https://importarvagalemania.vercel.app/catalogo" },
      { "@type": "ListItem", position: 3, name: brand?.name ?? vehicle.brand, item: `https://importarvagalemania.vercel.app/catalogo/${vehicle.brandSlug}` },
      { "@type": "ListItem", position: 4, name: vehicle.model, item: `https://importarvagalemania.vercel.app/catalogo/${vehicle.brandSlug}/${vehicle.modelSlug}` },
      { "@type": "ListItem", position: 5, name: vehicle.trim, item: canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>
  <main class="overflow-x-hidden bg-[#f7f7f7]">
    <PageHero {...detailHero} activePath="/catalogo" />
    <Breadcrumbs items={breadcrumbItems} />
    <VehicleDetailSection
      vehicle={vehicle}
      sidebar={detailSidebar}
      popularVehicles={popularVehicles}
      questionCard={detailQuestionCard}
    />
    <FooterSection />
  </main>
</Layout>
