---
import FooterSection from "../components/home/FooterSection.astro";
import PageHero from "../components/shared/PageHero.astro";
import { siteMeta, siteUrl } from "../data/site";
import Layout from "../layouts/Layout.astro";

const canonical = `${siteUrl}/politica-cookies`;
const title = "Politica de Cookies | Importar VAG Alemania";
const description =
  "Informacion sobre el uso de cookies tecnicas y de terceros, su finalidad y como gestionarlas en Importar VAG Alemania.";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: title,
  description,
  url: canonical
};
---

<Layout title={title} description={description} canonical={canonical} schema={schema}>
  <main class="overflow-x-hidden bg-[#f6f6f6] text-[#141414]">
    <PageHero
      title="Politica de cookies"
      backgroundImage="http://demo2.strongtheme.com/autocar/wp-content/uploads/sites/3/2021/07/autohome023.png"
      activePath="/politica-cookies"
    />

    <section class="px-5 py-12 sm:px-8 lg:px-10">
      <div class="mx-auto max-w-[900px] rounded-[10px] border border-[#e5e5e5] bg-white p-6 shadow-[0_10px_24px_rgba(0,0,0,0.04)] sm:p-8">
        <p class="text-sm text-[#666666]">Ultima actualizacion: 9 de marzo de 2026</p>

        <h2 class="mt-6 font-['Montserrat'] text-[24px] font-bold">1. Que son las cookies</h2>
        <p class="mt-3 text-[15px] leading-7 text-[#4f4f4f]">
          Las cookies son pequenos archivos que se almacenan en tu dispositivo al visitar una web. Permiten funciones tecnicas, recordar
          preferencias o recopilar informacion estadistica sobre la navegacion.
        </p>

        <h2 class="mt-8 font-['Montserrat'] text-[24px] font-bold">2. Tipos de cookies utilizadas en este sitio</h2>
        <ul class="mt-3 list-disc space-y-2 pl-5 text-[15px] leading-7 text-[#4f4f4f]">
          <li><strong>Cookies tecnicas necesarias:</strong> imprescindibles para el funcionamiento basico del sitio y su seguridad.</li>
          <li><strong>Cookies de terceros asociadas a servicios externos:</strong> pueden activarse al usar formularios o infraestructuras de hosting.</li>
        </ul>
        <p class="mt-3 text-[15px] leading-7 text-[#4f4f4f]">
          Actualmente este sitio no utiliza, por defecto, panel propio de analitica comportamental con perfilado publicitario.
        </p>

        <h2 class="mt-8 font-['Montserrat'] text-[24px] font-bold">3. Cookies de terceros</h2>
        <p class="mt-3 text-[15px] leading-7 text-[#4f4f4f]">
          Algunos proveedores tecnicos pueden instalar cookies propias cuando interactuas con sus servicios, por ejemplo:
        </p>
        <ul class="mt-2 list-disc space-y-2 pl-5 text-[15px] leading-7 text-[#4f4f4f]">
          <li>Infraestructura y despliegue web (Vercel).</li>
          <li>Procesamiento de formularios de contacto (FormSubmit).</li>
        </ul>
        <p class="mt-3 text-[15px] leading-7 text-[#4f4f4f]">
          Te recomendamos revisar las politicas de privacidad y cookies de dichos terceros para conocer el detalle actualizado.
        </p>

        <h2 class="mt-8 font-['Montserrat'] text-[24px] font-bold">4. Gestion y desactivacion</h2>
        <p class="mt-3 text-[15px] leading-7 text-[#4f4f4f]">
          Puedes permitir, bloquear o eliminar cookies desde la configuracion de tu navegador. La desactivacion de cookies tecnicas puede afectar
          al funcionamiento de algunas partes del sitio.
        </p>

        <h2 class="mt-8 font-['Montserrat'] text-[24px] font-bold">5. Contacto</h2>
        <p class="mt-3 text-[15px] leading-7 text-[#4f4f4f]">
          Para cualquier consulta sobre esta politica de cookies, puedes escribir a
          <a href={`mailto:${siteMeta.email}`} class="text-[#d10000] hover:underline"> {siteMeta.email}</a>.
        </p>
      </div>
    </section>

    <FooterSection />
  </main>
</Layout>
